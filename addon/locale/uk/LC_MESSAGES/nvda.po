#. Announce orientation
#: addon\globalPlugins\tesseractOCR\__init__.py:185
#, fuzzy
#| msgid "Page is positioned correctly. Do you want to process the OCR?"
msgid "Page is positioned correctly."
msgstr ""
"Сторінка розташована правильно. Ви хочете обробити розпізнавання тексту?"

